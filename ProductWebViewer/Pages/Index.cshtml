@page
@model IndexModel
@{
    ViewData["Title"] = "登録実績";
    var isProduct = Model.Tab != "substrate";
    var isSerial  = Model.SubTab == "serial";
    var isStock   = Model.SubTab == "stock";
}

@section Styles {
<style>
    .resizable-table th {
        position: relative;
        overflow: hidden;
        white-space: nowrap;
    }
    .resizable-table td {
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
    .col-resizer {
        position: absolute;
        right: 0;
        top: 0;
        width: 5px;
        height: 100%;
        cursor: col-resize;
        user-select: none;
    }
    .col-resizer:hover,
    .col-resizer.resizing {
        background-color: #0d6efd;
        opacity: 0.5;
    }
    .list-box {
        height: 150px;
        overflow-y: auto;
        border: 1px solid #dee2e6;
        border-radius: 4px;
    }
    .list-box select {
        width: 100%;
        height: 100%;
        border: none;
        font-size: 0.85rem;
        background: transparent;
    }
    .list-box select:focus {
        outline: none;
        box-shadow: none;
    }
</style>
}

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    // 列幅の自動計算
    document.querySelectorAll('.resizable-table').forEach(function (table) {
        table.style.tableLayout = 'auto';
        var ths = Array.from(table.querySelectorAll('thead th'));
        var widths = ths.map(function (th) { return th.offsetWidth; });
        ths.forEach(function (th, i) { th.style.width = widths[i] + 'px'; });
        table.style.tableLayout = 'fixed';
    });

    // 列幅ドラッグハンドル
    document.querySelectorAll('.resizable-table').forEach(function (table) {
        table.querySelectorAll('th').forEach(function (th) {
            var handle = document.createElement('div');
            handle.className = 'col-resizer';
            th.appendChild(handle);
            var startX, startW;
            handle.addEventListener('mousedown', function (e) {
                startX = e.pageX;
                startW = th.offsetWidth;
                handle.classList.add('resizing');
                function onMouseMove(e) {
                    th.style.width = Math.max(40, startW + (e.pageX - startX)) + 'px';
                }
                function onMouseUp() {
                    handle.classList.remove('resizing');
                    document.removeEventListener('mousemove', onMouseMove);
                    document.removeEventListener('mouseup', onMouseUp);
                }
                document.addEventListener('mousemove', onMouseMove);
                document.addEventListener('mouseup', onMouseUp);
                e.preventDefault();
            });
        });
    });

    // 製品タブ カスケードリストボックス
    var listProductCategory = document.getElementById('listProductCategory');
    var listProductName     = document.getElementById('listProductName');
    var listProductType     = document.getElementById('listProductType');

    if (listProductCategory) {
        listProductCategory.addEventListener('change', function () {
            listProductName.value = '';
            listProductType.value = '';
            this.form.submit();
        });
        listProductName.addEventListener('change', function () {
            listProductType.value = '';
            this.form.submit();
        });
        listProductType.addEventListener('change', function () {
            this.form.submit();
        });
    }

    // 基板タブ カスケードリストボックス
    var listSubCategory    = document.getElementById('listSubCategory');
    var listSubProductName = document.getElementById('listSubProductName');
    var listSubstrateName  = document.getElementById('listSubstrateName');

    if (listSubCategory) {
        listSubCategory.addEventListener('change', function () {
            listSubProductName.value = '';
            listSubstrateName.value  = '';
            this.form.submit();
        });
        listSubProductName.addEventListener('change', function () {
            listSubstrateName.value = '';
            this.form.submit();
        });
        listSubstrateName.addEventListener('change', function () {
            this.form.submit();
        });
    }
});

function switchSubTab(subTab) {
    document.getElementById('subTabInput').value = subTab;
    document.querySelector('form').submit();
}

function switchStockGroup(group) {
    document.getElementById('stockGroupInput').value = group;
    document.getElementById('subTabInput').value = 'stock';
    document.querySelector('form').submit();
}
</script>
}

<h4 class="mb-3">登録実績一覧</h4>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(isProduct ? "active" : "")" href="?tab=product">製品登録実績</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(!isProduct ? "active" : "")" href="?tab=substrate">基板登録実績</a>
    </li>
</ul>

@if (Model.ErrorMessage is not null) {
    <div class="alert alert-danger">@Model.ErrorMessage</div>
} else if (isProduct) {

    <form method="get">
        <input type="hidden" name="tab" value="product" />
        <input type="hidden" id="subTabInput" name="SubTab" value="@Model.SubTab" />

        <div class="row g-2 mb-2">
            <div class="col-2">
                <div class="fw-bold small mb-1">カテゴリ</div>
                <div class="list-box">
                    <select id="listProductCategory" name="ListProductCategory" size="10">
                        <option value="">（すべて）</option>
                        @foreach (var item in Model.ProductCategoryList) {
                            if (Model.ListProductCategory == item) {
                                <option value="@item" selected>@item</option>
                            } else {
                                <option value="@item">@item</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-2">
                <div class="fw-bold small mb-1">製品名</div>
                <div class="list-box">
                    <select id="listProductName" name="ListProductName" size="10">
                        <option value="">（すべて）</option>
                        @foreach (var item in Model.ProductNameList) {
                            if (Model.ListProductName == item) {
                                <option value="@item" selected>@item</option>
                            } else {
                                <option value="@item">@item</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-2">
                <div class="fw-bold small mb-1">タイプ</div>
                <div class="list-box">
                    <select id="listProductType" name="ListProductType" size="10">
                        <option value="">（すべて）</option>
                        @foreach (var item in Model.ProductTypeList) {
                            if (Model.ListProductType == item) {
                                <option value="@item" selected>@item</option>
                            } else {
                                <option value="@item">@item</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-6 d-flex flex-column justify-content-between">
                <div class="row g-2">
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterProductName"
                               value="@Model.FilterProductName" placeholder="製品名（テキスト）" />
                    </div>
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterProductOrderNumber"
                               value="@Model.FilterProductOrderNumber" placeholder="注文番号" />
                    </div>
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterProductRegDateFrom"
                               value="@Model.FilterProductRegDateFrom" placeholder="登録日 From" style="width:120px;" />
                    </div>
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterProductRegDateTo"
                               value="@Model.FilterProductRegDateTo" placeholder="登録日 To" style="width:120px;" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-sm btn-primary">検索</button>
                    </div>
                    <div class="col-auto">
                        <a href="?tab=product" class="btn btn-sm btn-secondary">リセット</a>
                    </div>
                </div>
                @if (isSerial) {
                    <div class="row g-2 mt-1">
                        <div class="col-auto">
                            <input type="text" class="form-control form-control-sm" name="FilterSerial"
                                   value="@Model.FilterSerial" placeholder="シリアル番号" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-sm btn-primary">検索</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="d-flex align-items-center gap-3 mb-2">
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn @(!isSerial ? "btn-primary" : "btn-outline-secondary")"
                        onclick="switchSubTab('records')">登録実績</button>
                <button type="button" class="btn @(isSerial ? "btn-primary" : "btn-outline-secondary")"
                        onclick="switchSubTab('serial')">シリアル履歴</button>
            </div>
            <span class="text-muted small">
                @(isSerial ? Model.SerialRecords.Count : Model.ProductRecords.Count) 件（最大 500 件）
            </span>
        </div>

        <div class="table-responsive">
            @if (!isSerial) {
                <table class="table table-bordered table-sm table-hover resizable-table">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>カテゴリ</th>
                            <th>製品名</th>
                            <th>型式</th>
                            <th>種別</th>
                            <th>注文番号</th>
                            <th>製番</th>
                            <th>O-Les番号</th>
                            <th>数量</th>
                            <th>担当者</th>
                            <th>登録日</th>
                            <th>Revision</th>
                            <th>シリアル開始</th>
                            <th>シリアル終了</th>
                            <th>コメント</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.ProductRecords) {
                            <tr>
                                <td>@r.Id</td>
                                <td>@r.CategoryName</td>
                                <td>@r.ProductName</td>
                                <td>@r.ProductModel</td>
                                <td>@r.ProductType</td>
                                <td>@r.OrderNumber</td>
                                <td>@r.ProductNumber</td>
                                <td>@r.OLesNumber</td>
                                <td>@r.Quantity</td>
                                <td>@r.Person</td>
                                <td>@r.RegDate</td>
                                <td>@r.Revision</td>
                                <td>@r.SerialFirst</td>
                                <td>@r.SerialLast</td>
                                <td>@r.Comment</td>
                            </tr>
                        }
                    </tbody>
                </table>
            } else {
                <table class="table table-bordered table-sm table-hover resizable-table">
                    <thead class="table-light">
                        <tr>
                            <th>No.</th>
                            <th>シリアル番号</th>
                            <th>O-Lesシリアル</th>
                            <th>注文番号</th>
                            <th>製番</th>
                            <th>製品名</th>
                            <th>種別</th>
                            <th>型式</th>
                            <th>登録日</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.SerialRecords) {
                            <tr>
                                <td>@r.RowId</td>
                                <td>@r.Serial</td>
                                <td>@r.OLesSerial</td>
                                <td>@r.OrderNumber</td>
                                <td>@r.ProductNumber</td>
                                <td>@r.ProductName</td>
                                <td>@r.ProductType</td>
                                <td>@r.ProductModel</td>
                                <td>@r.RegDate</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </form>

} else {

    <form method="get">
        <input type="hidden" name="tab" value="substrate" />
        <input type="hidden" id="subTabInput" name="SubTab" value="@Model.SubTab" />
        <input type="hidden" id="stockGroupInput" name="StockGroup" value="@Model.StockGroup" />

        <div class="row g-2 mb-2">
            <div class="col-2">
                <div class="fw-bold small mb-1">カテゴリ</div>
                <div class="list-box">
                    <select id="listSubCategory" name="ListSubCategory" size="10">
                        <option value="">（すべて）</option>
                        @foreach (var item in Model.SubCategoryList) {
                            if (Model.ListSubCategory == item) {
                                <option value="@item" selected>@item</option>
                            } else {
                                <option value="@item">@item</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-2">
                <div class="fw-bold small mb-1">製品名</div>
                <div class="list-box">
                    <select id="listSubProductName" name="ListSubProductName" size="10">
                        <option value="">（すべて）</option>
                        @foreach (var item in Model.SubProductNameList) {
                            if (Model.ListSubProductName == item) {
                                <option value="@item" selected>@item</option>
                            } else {
                                <option value="@item">@item</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-2">
                <div class="fw-bold small mb-1">基板名</div>
                <div class="list-box">
                    <select id="listSubstrateName" name="ListSubstrateName" size="10">
                        <option value="">（すべて）</option>
                        @foreach (var item in Model.SubstrateNameList) {
                            if (Model.ListSubstrateName == item) {
                                <option value="@item" selected>@item</option>
                            } else {
                                <option value="@item">@item</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-6 d-flex flex-column justify-content-end">
                <div class="row g-2">
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterSubstrateName"
                               value="@Model.FilterSubstrateName" placeholder="基板名（テキスト）" />
                    </div>
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterSubstrateOrderNumber"
                               value="@Model.FilterSubstrateOrderNumber" placeholder="注文番号" />
                    </div>
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterSubstrateRegDateFrom"
                               value="@Model.FilterSubstrateRegDateFrom" placeholder="登録日 From" style="width:120px;" />
                    </div>
                    <div class="col-auto">
                        <input type="text" class="form-control form-control-sm" name="FilterSubstrateRegDateTo"
                               value="@Model.FilterSubstrateRegDateTo" placeholder="登録日 To" style="width:120px;" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-sm btn-primary">検索</button>
                    </div>
                    <div class="col-auto">
                        <a href="?tab=substrate" class="btn btn-sm btn-secondary">リセット</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3 mb-2">
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn @(!isStock ? "btn-primary" : "btn-outline-secondary")"
                        onclick="switchSubTab('records')">登録実績</button>
                <button type="button" class="btn @(isStock ? "btn-primary" : "btn-outline-secondary")"
                        onclick="switchSubTab('stock')">在庫数</button>
            </div>
            @if (isStock) {
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn @(Model.StockGroup != "detail" ? "btn-info" : "btn-outline-info")"
                            onclick="switchStockGroup('model')">基板単位</button>
                    <button type="button" class="btn @(Model.StockGroup == "detail" ? "btn-info" : "btn-outline-info")"
                            onclick="switchStockGroup('detail')">製造番号単位</button>
                </div>
            }
            <span class="text-muted small">
                @(isStock ? Model.StockRecords.Count : Model.SubstrateRecords.Count) 件
                @(!isStock ? "（最大 500 件）" : "")
            </span>
        </div>

        <div class="table-responsive">
            @if (!isStock) {
                <table class="table table-bordered table-sm table-hover resizable-table">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>カテゴリ</th>
                            <th>製品名</th>
                            <th>基板名</th>
                            <th>基板型式</th>
                            <th>注文番号</th>
                            <th>製造番号</th>
                            <th>入庫</th>
                            <th>出庫</th>
                            <th>不良</th>
                            <th>担当者</th>
                            <th>登録日</th>
                            <th>コメント</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.SubstrateRecords) {
                            <tr>
                                <td>@r.Id</td>
                                <td>@r.CategoryName</td>
                                <td>@r.ProductName</td>
                                <td>@r.SubstrateName</td>
                                <td>@r.SubstrateModel</td>
                                <td>@r.OrderNumber</td>
                                <td>@r.SubstrateNumber</td>
                                <td>@r.Increase</td>
                                <td>@r.Decrease</td>
                                <td>@r.Defect</td>
                                <td>@r.Person</td>
                                <td>@r.RegDate</td>
                                <td>@r.Comment</td>
                            </tr>
                        }
                    </tbody>
                </table>
            } else {
                <table class="table table-bordered table-sm table-hover resizable-table">
                    <thead class="table-light">
                        <tr>
                            <th>カテゴリ</th>
                            <th>製品名</th>
                            <th>基板名</th>
                            <th>基板型式</th>
                            @if (Model.StockGroup == "detail") {
                                <th>製造番号</th>
                                <th>注文番号</th>
                            }
                            <th>在庫数</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.StockRecords) {
                            <tr>
                                <td>@r.CategoryName</td>
                                <td>@r.ProductName</td>
                                <td>@r.SubstrateName</td>
                                <td>@r.SubstrateModel</td>
                                @if (Model.StockGroup == "detail") {
                                    <td>@r.SubstrateNumber</td>
                                    <td>@r.OrderNumber</td>
                                }
                                <td>@r.Stock</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </form>
}
